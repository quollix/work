#!/usr/bin/env bash
set -euo pipefail

scriptDirectory="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
source "$scriptDirectory/work-common.sh"

projectName="${1:-}"

if [ -z "$projectName" ]; then
    echo "usage: work <projectName>"
    exit 1
fi

work_ensure_session "$projectName" "$scriptDirectory"
work_enter_session "$projectName"
